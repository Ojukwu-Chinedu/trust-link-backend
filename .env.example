# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/trustlink_db"

# Server Configuration
PORT=3000
NODE_ENV=development

# Authentication & Security
SEP10_JWT_SECRET="your-super-secure-jwt-secret-at-least-32-characters-long"
ADMIN_ADDRESS="GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# Stellar Network Configuration
STELLAR_NETWORK=TESTNET

# Optional: Notification Services
SENDGRID_API_KEY="your-sendgrid-api-key"
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"

# Issue #85 – CORS: comma-separated list of allowed frontend origins.
# Requests from any origin not in this list will be rejected with 403.
# Leave empty to allow all origins in development, block all in production.
# Example: ALLOWED_ORIGINS="https://app.trust-link.io,https://staging.trust-link.io"
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# Issue #76 – Stellar Horizon webhook HMAC secret.
# Horizon signs each webhook payload with this secret (HMAC-SHA256).
# The value must match what is configured in your Horizon callback settings.
# If unset, signature verification is skipped (development only).
STELLAR_WEBHOOK_SECRET="your-stellar-webhook-hmac-secret"

# Issue #81 – Minimum log level emitted by the structured JSON logger.
# Valid values: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
